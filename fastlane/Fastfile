# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

import "helpers/build.rb"
import "helpers/keysafe.rb"
import "helpers/publish/google_play.rb"
import "helpers/publish/huawei.rb"
import "helpers/publish/firebase_app_distribution.rb"
import "helpers/tests.rb"

default_platform(:android)

platform :android do
  before_all do |_lane, options|
    # Download keys repo and set it up
    init_keysafe(options.fetch(:app_name))
  end

  after_all do |_lane, _options|
    # Remove secrets if no longer needed
    delete_keysafe
  end

  error do |_lane, _exception|
    # Remove secrets if no longer needed
    delete_keysafe
    # Send error notification
  end

  desc "Run unit tests in the project"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  desc "* `clean` - (Optional) Boolean that enables cleaning the project before running. Defaults to false."
  desc ""
  desc "Returns:"
  desc "* a `TestsResult` object containing whether or not the tests passed and an array of JUnit XML files."
  lane :unit_tests do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""
    clean_project = options[:clean] || false

    clean if clean_project

    run_unit_tests(app_module, app_variant)
  end

  desc "Run instrumented tests in the project using Firebase Test Lab."
  desc ""
  desc "Ensure that you have installed `gcloud` and `gsutil` in your system and are accesible in PATH before running this lane."
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  desc "* `clean` - (Optional) Boolean that enables cleaning the project before running. Defaults to false."
  desc ""
  desc "Returns:"
  desc "* a `TestsResult` object containing whether or not the tests passed and an array of JUnit XML files."
  lane :instrumented_tests_in_firebase_test_lab do |options|
    app_name = options.fetch(:app_name)
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""
    clean_project = options[:clean] || false

    clean if clean_project

    # Build the app in debug mode and the test APK
    debug_apk_result = debug_apk(app_name: app_name, app_module: app_module, app_variant: app_variant)
    debug_apk_path = debug_apk_result.apk_path

    tests_apk_result = tests_apk(app_name: app_name, app_module: app_module, app_variant: app_variant)
    tests_apk_path = tests_apk_result.apk_path

    # Test in Firebase Test Lab
    ftl_data = get_firebase_test_lab_data
    run_instrumented_tests_in_firebase_test_lab(
      ftl_data.project_id,
      ftl_data.service_account_json_path,
      debug_apk_path,
      tests_apk_path
    )
  end

  desc "Generates a debug APK build of the app"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  desc "* `clean` - (Optional) Boolean that enables cleaning the project before running. Defaults to false."
  desc ""
  desc "Returns:"
  desc "* `BuildResult` object containing the generated APK path and the Proguard Mapping file if generated"
  lane :debug_apk do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""
    clean_project = options[:clean] || false

    clean if clean_project

    build_debug_apk(app_module, app_variant)
  end

  desc "Generates a test APK build of the app to use with a debug APK to run instrumented tests"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  desc "* `clean` - (Optional) Boolean that enables cleaning the project before running. Defaults to false."
  desc ""
  desc "Returns:"
  desc "* a `BuildResult` object containing the generated APK path and the Proguard Mapping file if generated"
  lane :tests_apk do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""
    clean_project = options[:clean] || false

    clean if clean_project

    build_instrumented_tests_apk(app_module, app_variant)
  end

  desc "Generates a release APK build of the app"
  desc ""
  desc "Ensure that the apps' `signingConfig` blocks are defined and that they can be obtained from the Gradle project like this:"
  desc "```groovy"
  desc "project.property(\"releaseKeystorePath\")"
  desc "project.property(\"releaseKeystorePwd\")"
  desc "project.property(\"releaseKeystoreAlias\")"
  desc "project.property(\"releaseKeystoreAliasPwd\")"
  desc "```"
  desc "If you add the `property_prefix` parameter, don't forget to include it in your key loading. For example, if you set `free` "
  desc "as the prefix, you'll have the following project properties:"
  desc "```groovy"
  desc "project.property(\"freeReleaseKeystorePath\")"
  desc "project.property(\"freeReleaseKeystorePwd\")"
  desc "project.property(\"freeReleaseKeystoreAlias\")"
  desc "project.property(\"freeReleaseKeystoreAliasPwd\")"
  desc "```"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  desc "* `clean` - (Optional) Boolean that enables cleaning the project before running. Defaults to false."
  desc "* `property_prefix` - (Optional) Prefix to add to keystore variables' names. Defaults to empty string."
  desc ""
  desc "Returns:"
  desc "* a `BuildResult` object containing the generated APK path and the Proguard Mapping file if generated"
  lane :release_apk do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""
    clean_project = options[:clean] || false
    property_prefix = options[:property_prefix] || ""

    clean if clean_project

    keys_data = get_keys_data
    build_release_apk(app_module,
      app_variant,
      keys_data.upload_keystore_path,
      keys_data.upload_keystore_password,
      keys_data.upload_keystore_alias,
      keys_data.upload_keystore_alias_password,
      property_prefix)
  end

  desc "Publishes an APK to the Google Play Store in the given track"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `track` - The track to use when publishing."
  desc "* `apk_paths` - Comma-separated list of absolute paths to the APKs to publish."
  desc "* `mapping_paths` - Comma-separated list of absolute paths to the Proguard mapping paths to attach to the publication. Defaults to nil."
  desc ""
  desc "Returns:"
  desc "* a `PublishVersionResult` object containing if the publication was published and the version name of the published app"
  lane :publish_apk_play_store do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    track = options.fetch(:track)
    apk_paths = options.fetch(:apk_paths).split(",")
    mapping_paths = options[:mapping_path]&.split(",")

    google_play_data = get_google_play_data
    publish_apk_to_google_play_store(track,
      apk_paths,
      mapping_paths,
      google_play_data.package_name,
      google_play_data.upload_service_account_json_path)
  end

  desc "Publishes an APK to HUAWEI AppGallery."
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `submit_for_review` - (Optional) Whether or not submit for review. Defaults to false."
  desc "* `apk_path` - Absolute path to the APK to publish."
  desc ""
  desc "Returns:"
  desc "* a `PublishVersionResult` object containing if the publication was published and the version name of the published app"
  lane :publish_apk_appgallery do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    submit_for_review = options[:submit_for_review] || false
    apk_path = options.fetch(:apk_path)

    huawei_data = get_huawei_data
    publish_apk_to_huawei_appgallery(submit_for_review,
      apk_path,
      huawei_data.api_client_id,
      huawei_data.api_client_secret,
      huawei_data.app_id)
  end

  desc "Promotes the version in a track into another track in Google Play Store, with a given staged rollout percentage."
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `from_track` - The track to promote from."
  desc "* `to_track` - The track to promote to."
  desc "* `staged_rollout_percentage` - (Optional) Float from 0 to 100 to perform a staged rollout, or nil if no staged rollout"
  desc ""
  desc "Returns:"
  desc "* a `PublishVersionResult` object containing if the publication was published and the version name of the published app"
  lane :promote_google_play_store do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    from_track = options.fetch(:from_track)
    to_track = options.fetch(:to_track)
    staged_rollout_percentage = options[:staged_rollout_percentage]

    google_play_data = get_google_play_data
    promote_google_play_store_track(
      from_track,
      to_track,
      google_play_data.package_name,
      google_play_data.upload_service_account_json_path,
      staged_rollout_percentage
    )
  end

  desc "Updates the version to submit for review in HUAWEI AppGallery"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `staged_rollout_percentage` - (Optional) Float from 0 to 100 to perform a staged rollout, or nil if no staged rollout"
  desc ""
  desc "Returns:"
  desc "* a `PublishVersionResult` object containing if the publication was published and the version name of the published app"
  lane :submit_for_review_appgallery do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    rollout_percentage = options[:staged_rollout_percentage]

    is_phased_release = !rollout_percentage.nil?

    huawei_data = get_huawei_data
    update_huawei_appgallery_release_for_review(
      huawei_data.api_client_id,
      huawei_data.api_client_secret,
      huawei_data.app_id,
      is_phased_release,
      rollout_percentage
    )
  end

  desc "Uploads an APK to Firebase App Distribution"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `apk_path` - Absolute path to the APK to publish."
  desc "* `app_variant` - (Optional) Comma separated list of the flavors that compose the variant of the app. Defaults to \"release\"."
  desc "* `tester_emails` - (Optional) Comma separated list of tester emails. Defaults to nil."
  desc "* `tester_groups` - (Optional) Comma separated list of tester groups. Defaults to nil."
  desc "* `release_notes` - (Optional) Release notes for the version. Defaults to nil"
  desc ""
  desc "Returns:"
  desc "* a `PublishVersionResult` object containing if the publication was published"
  lane :publish_apk_to_firebase_app_distribution do |options|
    # app_name is not read here, but in before_all block, so we need it anyway
    apk_path = options.fetch(:apk_path)
    app_variant = options[:app_variant] ? options[:app_variant].split(",") : ["release"]
    tester_emails = options[:tester_emails]
    tester_groups = options[:tester_groups]
    release_notes = options[:release_notes]

    firebase_app_distribution_data = get_firebase_app_distribution_data
    firebase_app_id = firebase_app_distribution_data.build_variant_app_id_hash[app_variant]
    firebase_app_distribution_service_account_json_path = firebase_app_distribution_data.service_account_json_path

    upload_to_firebase_app_distribution(
      firebase_app_id,
      apk_path,
      firebase_app_distribution_service_account_json_path,
      tester_emails,
      tester_groups,
      release_notes
    )
  end

  desc "Builds, tests and publishes an app version to stores' internal tracks."
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  desc "* `app_module` - (Optional) The module to build. Defaults to `app`."
  desc "* `app_variant` - (Optional) Comma separated list off the flavors that compose the variant of the app. Defaults to empty string."
  lane :generate_internal do |options|
    # Gather parameters
    app_name = options[:app_name]
    app_module = options[:app_module] || "app"
    app_variant = options[:app_variant] ? options[:app_variant].split(",").map { |s| s.strip.capitalize }.join : ""

    # Clean cached data
    clean

    # Run unit tests: if they pass, go to next step, else stop the lane
    unit_tests_results = unit_tests(app_name: app_name, app_module: app_module, app_variant: app_variant)
    unless unit_tests_results.passed
      # TODO: Send test results somewhere
      UI.test_failure!("Unit tests for app #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "}didn't pass")
    end

    # Test in Firebase Test Lab: if everything is OK, perform the next step, else stop the lane
    instrumented_tests_results = instrumented_tests_in_firebase_test_lab(
      app_name: app_name,
      app_module: app_module,
      app_variant: app_variant
    )
    unless instrumented_tests_results.passed
      # TODO: Send test results somewhere
      UI.test_failure!("Instrumented tests for app #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "}didn't pass")
    end

    # Build release binary
    release_apk_result = release_apk(app_name: app_name, app_module: app_module, app_variant: app_variant)
    unless release_apk_result.successful
      UI.build_failure!("Release binary for app #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "}failed")
    end

    # Google Play: publish to internal track
    google_play_upload_result = publish_apk_play_store(
      app_name: app_name,
      track: "internal",
      apk_paths: [release_apk_result.apk_path],
      mapping_paths: [release_apk_result.mapping_path]
    )

    if google_play_upload_result.published
      UI.success("App #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "} published in Google Play Store's internal track!")
    else
      # Explicit error here, the Play Store is our main store, so if we can't publish, forget about publishing in other stores
      UI.abort_with_message!("App #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "} could not be published to Google Play Store's internal track")
    end

    # Huawei AppGallery: publish without sending it to review
    huawei_upload_result = publish_apk_appgallery(
      app_name: app_name,
      submit_for_review: false,
      apk_path: release_apk_result.apk_path
    )

    if huawei_upload_result.published
      UI.success("App #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "} sent to HUAWEI AppGallery!")
    else
      # Simple error, just warn that the app wasn't published
      UI.abort_with_message!("App #{app_name} #{app_variant.empty? ? "" : "and variant #{app_variant} "} could not be sent to HUAWEI AppGallery")
    end
  end

  desc "Promote internal track binary to alpha track in stores"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  lane :promote_internal_to_alpha do |options|
    # Gather parameters
    app_name = options[:app_name]

    # Google Play Store: promote internal to alpha
    google_play_upload_result = promote_google_play_store(
      app_name: app_name,
      from_track: "internal",
      to_track: "alpha"
    )

    # Huawei AppGallery: do nothing

    if google_play_upload_result.published
      UI.success("App #{app_name} version #{google_play_upload_result.version_name} promoted to Google Play alpha track")
    else
      UI.abort_with_message!("App #{app_name} could not be promoted to Google Play alpha track")
    end
  end

  desc "Promote alpha track binary to production track in stores with 20% rollout"
  desc ""
  desc "Options:"
  desc "* `app_name` - Name of the app in the keysafe."
  lane :promote_alpha_to_production do |options|
    # Gather parameters
    app_name = options[:app_name]

    rollout_percentage = 20.0

    # Google Play Store: promote from alpha to production with staged rollout
    google_play_upload_result = promote_google_play_store(
      app_name: app_name,
      from_track: "alpha",
      to_track: "production",
      staged_rollout_percentage: rollout_percentage
    )

    if google_play_upload_result.published
      UI.success("App #{app_name} version #{google_play_upload_result.version_name} promoted to Google Play production with 20% rollout!")
    else
      UI.abort_with_message!("App #{app_name} could not be promoted to Google Play production track")
    end

    # Huawei AppGallery: send the current version as review, and start a 20% phased release
    # We'll set the release phase period up to 30 days so we can deal with cancelling later or updating
    # to a full release
    huawei_upload_result = submit_for_review_appgallery(
      app_name: app_name,
      staged_rollout_percentage: rollout_percentage
    )

    if huawei_upload_result.published
      UI.success("App #{app_name} submitted for review to HUAWEI AppGallery with 20% rollout!")
    else
      UI.abort_with_message!("App #{app_name} could not be sumbitted for review to HUAWEI AppGallery")
    end
  end

  desc "Update production staged rollout percentage"
  lane :update_production_percentage do |options|
    # Gather parameters
    app_name = options[:app_name]

    rollout_percentage = 100.0

    # Google Play Store: change production staged rollout percentage
    google_play_upload_result = promote_google_play_store(
      app_name: app_name,
      from_track: "production",
      to_track: "production",
      staged_rollout_percentage: rollout_percentage
    )

    if google_play_upload_result.uploaded
      UI.success("App #{app_name} version #{google_play_upload_result.version_name} promoted to Google Play production track!")
    else
      UI.abort_with_message!("App #{app_name} could not be promoted to Google Play production track")
    end

    # Huawei AppGallery: change production staged rollout percentage
    huawei_upload_result = submit_for_review_appgallery(
      app_name: app_name,
      staged_rollout_percentage: rollout_percentage
    )

    if huawei_upload_result.uploaded
      UI.success("App #{app_name} submitted for review to HUAWEI AppGallery!")
    else
      UI.abort_with_message!("App #{app_name} could not be sumbitted for review to HUAWEI AppGallery")
    end
  end
end
